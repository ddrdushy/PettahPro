{
  "name": "pettahpro",
  "version": "0.1.0",
  "private": true,
  "description": "PettahPro — cloud accounting and business operations for Sri Lankan SMEs",
  "repository": {
    "type": "git",
    "url": "https://github.com/ddrdushy/PettahPro.git"
  },
  "engines": {
    "node": ">=20.11.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev": "docker compose up",
    "dev:build": "docker compose up --build",
    "dev:down": "docker compose down",
    "dev:clean": "docker compose down -v",
    "dev:logs": "docker compose logs -f",
    "db:migrate": "pnpm --filter @pettahpro/db migrate",
    "db:studio": "pnpm --filter @pettahpro/db studio",
    "db:seed": "pnpm --filter @pettahpro/db seed",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\""
  },
  "devDependencies": {
    "@types/node": "^20.11.30",
    "prettier": "^3.2.5",
    "typescript": "^5.4.5"
  }
}
