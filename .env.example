# ==============================================================================
# PettahPro — local development environment
# Copy this file to `.env` and adjust as needed.
# ==============================================================================

# --- Postgres ---
# Superuser — runs init scripts, owns tables, used for migrations.
POSTGRES_USER=pettahpro
POSTGRES_PASSWORD=pettahpro_dev
POSTGRES_DB=pettahpro
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# App role — NOBYPASSRLS. The API/worker connect as this so dev exercises RLS
# the same way prod does. Created by docker/postgres/init/44-auth-helpers.sql.
POSTGRES_APP_USER=pettahpro_app
POSTGRES_APP_PASSWORD=pettahpro_app_dev

# PgBouncer port (transaction mode). Still running in docker-compose but not
# wired into DATABASE_URL below yet — edoburu/pgbouncer is single-user, so
# switching to multi-user auth_query is a follow-up before the app can route
# through it.
PGBOUNCER_PORT=6432

# App DSN uses the non-superuser role, connects directly to postgres.
DATABASE_URL=postgres://pettahpro_app:pettahpro_app_dev@localhost:5432/pettahpro

# Direct superuser connection (for migrations / admin tasks only).
DATABASE_URL_DIRECT=postgres://pettahpro:pettahpro_dev@localhost:5432/pettahpro

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# --- MinIO (local S3) ---
MINIO_ROOT_USER=pettahpro
MINIO_ROOT_PASSWORD=pettahpro_dev
MINIO_ENDPOINT=http://localhost:9000
MINIO_BUCKET=pettahpro-documents

# --- Mailhog (local SMTP) ---
SMTP_HOST=localhost
SMTP_PORT=1025

# --- API ---
API_PORT=4000
API_HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info

# --- Web ---
WEB_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:4000

# --- Auth (placeholder — replace in Phase 1) ---
JWT_SECRET=dev-secret-change-me-in-prod
SESSION_SECRET=dev-session-secret-change-me

# --- Observability ---
SENTRY_DSN=
