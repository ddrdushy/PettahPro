# ==============================================================================
# PettahPro — local development environment
# Copy this file to `.env` and adjust as needed.
# ==============================================================================

# --- Postgres ---
POSTGRES_USER=pettahpro
POSTGRES_PASSWORD=pettahpro_dev
POSTGRES_DB=pettahpro
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# App connects via PgBouncer (transaction mode — required for RLS)
PGBOUNCER_PORT=6432
DATABASE_URL=postgres://pettahpro:pettahpro_dev@localhost:6432/pettahpro

# Direct connection (for migrations only — bypasses PgBouncer)
DATABASE_URL_DIRECT=postgres://pettahpro:pettahpro_dev@localhost:5432/pettahpro

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# --- MinIO (local S3) ---
MINIO_ROOT_USER=pettahpro
MINIO_ROOT_PASSWORD=pettahpro_dev
MINIO_ENDPOINT=http://localhost:9000
MINIO_BUCKET=pettahpro-documents

# --- Mailhog (local SMTP) ---
SMTP_HOST=localhost
SMTP_PORT=1025

# --- API ---
API_PORT=4000
API_HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info

# --- Web ---
WEB_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:4000

# --- Auth (placeholder — replace in Phase 1) ---
JWT_SECRET=dev-secret-change-me-in-prod
SESSION_SECRET=dev-session-secret-change-me

# --- Observability ---
SENTRY_DSN=
